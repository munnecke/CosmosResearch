---
import Base from '../layouts/Base.astro';
---
<Base>
  <section class="hero">
    <h1>Cosmos Research Center</h1>
    <p>A multi-generational science and ideas platform — exploring cosmology, physics, health, and the questions that matter.</p>
  </section>

  <section class="card-grid" style="margin-bottom: var(--space-lg);">
    <a href="/blog" class="card" style="text-decoration:none;">
      <h3>Blog</h3>
      <p style="color:var(--c-text-muted);">Essays, research notes, and reflections on science and life.</p>
    </a>
    <a href="/lab" class="card" style="text-decoration:none;">
      <h3>Lab</h3>
      <p style="color:var(--c-text-muted);">Interactive experiments and computational explorations.</p>
    </a>
    <a href="/about" class="card" style="text-decoration:none;">
      <h3>About</h3>
      <p style="color:var(--c-text-muted);">Who we are and what drives this project.</p>
    </a>
    <a href="/rss.xml" class="card" style="text-decoration:none;">
      <h3>RSS</h3>
      <p style="color:var(--c-text-muted);">Subscribe to new posts.</p>
    </a>
  </section>
</Base>
