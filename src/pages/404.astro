---
import Base from '../layouts/Base.astro';
---

<Base title="Not found">
  <div style="padding: 96px 0 80px; text-align: center;">
    <div style="font-family: var(--mono); font-size: 10px; font-weight: 300; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ink3); margin-bottom: 20px;">
      404
    </div>
    <h1 style="font-size: 36px; font-weight: 400; color: var(--ink); margin-bottom: 16px;">
      Nothing here
    </h1>
    <p style="font-size: 16px; color: var(--ink2); margin-bottom: 36px; font-family: var(--serif);">
      This page doesn't exist — or not yet.
    </p>
    <a href="/" class="btn btn-fill">Back to home</a>
  </div>
</Base>
